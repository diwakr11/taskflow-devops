      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes{job=\"taskflow-api\"}",
          "legendFormat": "RSS Memory",
          "refId": "A"
        }
      ]
    }
